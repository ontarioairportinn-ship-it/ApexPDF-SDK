{
  "version": 6,
  "configurePresets": [
    {
      "name": "windows-x64-debug",
      "displayName": "Windows x64 Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/artifacts/windows-x64-debug",
      "architecture": { "value": "x64", "strategy": "external" },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTING": "ON"
      }
    },
    {
      "name": "windows-x64-release",
      "displayName": "Windows x64 Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/artifacts/windows-x64-release",
      "architecture": { "value": "x64", "strategy": "external" },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING": "ON"
      }
    },
    {
      "name": "windows-x64-asan",
      "displayName": "Windows x64 AddressSanitizer",
      "inherits": "windows-x64-debug",
      "binaryDir": "${sourceDir}/artifacts/windows-x64-asan",
      "cacheVariables": {
        "APX_ENABLE_ASAN": "ON"
      }
    },
    {
      "name": "windows-x64-analyze",
      "displayName": "Windows x64 Native Static Analysis",
      "inherits": "windows-x64-debug",
      "binaryDir": "${sourceDir}/artifacts/windows-x64-analyze",
      "cacheVariables": {
        "APX_ENABLE_STATIC_ANALYSIS": "ON"
      }
    }
  ],
  "buildPresets": [
    { "name": "windows-x64-debug", "configurePreset": "windows-x64-debug" },
    { "name": "windows-x64-release", "configurePreset": "windows-x64-release" },
    { "name": "windows-x64-asan", "configurePreset": "windows-x64-asan" },
    { "name": "windows-x64-analyze", "configurePreset": "windows-x64-analyze" }
  ],
  "testPresets": [
    {
      "name": "windows-x64-debug",
      "configurePreset": "windows-x64-debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "windows-x64-release",
      "configurePreset": "windows-x64-release",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "windows-x64-asan",
      "configurePreset": "windows-x64-asan",
      "output": { "outputOnFailure": true }
    }
  ],
  "packagePresets": [
    {
      "name": "windows-x64-release",
      "configurePreset": "windows-x64-release",
      "generators": ["ZIP"]
    }
  ]
}
